msgstr "Netværksfejl. Prøv igen."

#: includes/class-mailmojo-admin.php:489
msgid "Unauthorized. Please check the token."
msgstr "Ikke autoriseret. Kontroller nøglen."

#: includes/class-mailmojo-admin.php:491
